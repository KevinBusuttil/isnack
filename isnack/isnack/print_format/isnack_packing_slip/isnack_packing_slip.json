 "doc_type": "Packing Slip",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\n    .print-format {\n        font-family: \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n        color: #333;\n        font-size: 10pt;\n        line-height: 1.2;\n        padding: 15px !important;\n        background-color: transparent;\n        max-width: 850px;\n        margin: 0 auto;\n    }\n\n    @media print {\n        @page { size: A4; }\n        .print-format {\n            padding: 0 !important;\n            margin: 0 !important;\n            width: 100%;\n            max-width: 100% !important;\n        }\n        .page-break {\n            page-break-before: avoid !important;\n            display: block;\n        }\n    }\n\n    .print-heading {\n        border-bottom: 2px solid #333;\n        padding-bottom: 10px;\n        margin-bottom: 12px;\n    }\n\n    .doc-title {\n        color: #000;\n        text-transform: uppercase;\n        font-weight: 800;\n        margin: 0;\n        font-size: 18pt;\n    }\n\n    .label-grey {\n        font-size: 8pt;\n        color: #888;\n        text-transform: uppercase;\n        font-weight: bold;\n        margin-bottom: 3px;\n    }\n\n    .table-custom {\n        width: 100%;\n        margin-top: 8px;\n        border: 1px solid #d1d1d1;\n        border-collapse: collapse;\n    }\n\n    .table-custom th {\n        background-color: #f9f9f9 !important;\n        border: 1px solid #d1d1d1 !important;\n        padding: 5px 6px !important;\n        text-transform: uppercase;\n        font-size: 7.5pt;\n        color: #555;\n    }\n\n    .table-custom td {\n        border: 1px solid #d1d1d1 !important;\n        padding: 5px 6px !important;\n        vertical-align: middle;\n        font-size: 7.5pt;\n    }\n\n    .item-name-cell {\n        font-weight: bold;\n        font-size: 7.5pt;\n        display: block;\n        margin-bottom: 1px;\n    }\n\n    .item-description-text {\n        color: #666;\n        font-size: 7.5pt;\n        line-height: 1.2;\n    }\n\n    .weights-footer {\n        margin-top: 12px;\n        padding-top: 8px;\n        border-top: 1px solid #d1d1d1;\n        font-size: 9pt;\n    }\n    .package-stats {\n        margin-top: 12px;\n        padding-top: 8px;\n        border-top: 1px solid #d1d1d1;\n        font-size: 7pt;\n    }\n    .package-stats-heading {\n        font-weight: bold;\n        margin-bottom: 6px;\n        font-size: 8pt;\n    }\n    .package-stats-table {\n        width: 100%;\n        border-collapse: collapse;\n    }\n    .package-stats-table th,\n    .package-stats-table td {\n        padding: 4px 6px;\n        border-bottom: 1px solid #e5e5e5;\n    }\n    .package-stats-table th {\n        background: #f5f5f5;\n        text-align: left;\n    }\n</style>\n\n<div class=\"print-format\">\n    <div class=\"page-break\">\n\n        {# Resolve the source Delivery Note once so the header and addresses can reuse it. #}\n        {% set dn = frappe.get_doc(\"Delivery Note\", doc.delivery_note) if doc.delivery_note else None %}\n        {% set company = dn.company if dn else None %}\n\n        <div class=\"print-heading\">\n            <div class=\"row\">\n                <div class=\"col-xs-7\">\n                    <img src=\"{{ frappe.db.get_value('Company', company, 'company_logo') or '' }}\" style=\"max-height: 65px;\">\n                    <div style=\"margin-top: 8px; line-height: 1.3; font-size: 8pt;\">\n                        <strong style=\"font-size: 9.5pt;\">ISNACK SARL</strong><br>\n                        Industrial zone Technopole 1, Lot 67-68, Enfidha 4030, Sousse, Tunisia<br>\n                        <strong>VAT:</strong> 1861028KAM000 | <strong>Reg:</strong> C0195572024<br>\n                        <strong>Web:</strong> www.isnacks.eu | <strong>Email:</strong> administration@isnacks.eu\n                    </div>\n                </div>\n                <div class=\"col-xs-5 text-right\" style=\"font-size: 8pt;\">\n                    <h2 class=\"doc-title\">Packing Slip</h2>\n                    <div style=\"font-size: 10.5pt; font-weight: bold; color: #b11116; margin-bottom: 8px;\"># {{ doc.name }}</div>\n                    <strong>Date:</strong> {{ frappe.utils.formatdate(doc.posting_date if doc.get('posting_date') else doc.creation) }}\n                </div>\n            </div>\n        </div>\n\n        {% if dn %}\n        <div class=\"row\" style=\"margin-bottom: 15px; font-size: 8pt;\">\n            <div class=\"col-xs-3\">\n                <div class=\"label-grey\">Bill To</div>\n                <div style=\"font-size: 9.5pt; font-weight: bold;\">{{ dn.customer_name or dn.customer }}</div>\n                {% if dn.customer_address %}\n                    {% set bill_addr = frappe.get_doc(\"Address\", dn.customer_address) %}\n                    {{ bill_addr.address_line1 }}<br>\n                    {% if bill_addr.address_line2 %}{{ bill_addr.address_line2 }}<br>{% endif %}\n                    {{ bill_addr.city }}{% if bill_addr.pincode %}, {{ bill_addr.pincode }}{% endif %}<br>\n                    {{ bill_addr.country }}\n                {% endif %}\n                {% if dn.tax_id %}<br><strong>VAT No:</strong> {{ dn.tax_id }}{% endif %}\n            </div>\n            <div class=\"col-xs-3\">\n                <div class=\"label-grey\">Ship To</div>\n                {% if dn.shipping_address_name %}\n                    {% set ship_addr = frappe.get_doc(\"Address\", dn.shipping_address_name) %}\n                    <strong>{{ ship_addr.address_title or dn.customer_name }}</strong><br>\n                    {{ ship_addr.address_line1 }}{% if ship_addr.address_line2 %}, {{ ship_addr.address_line2 }}{% endif %}<br>\n                    {{ ship_addr.city }}{% if ship_addr.pincode %}, {{ ship_addr.pincode }}{% endif %}<br>\n                    {{ ship_addr.country }}\n                {% else %}\n                    <span style=\"color: #999;\">Same as billing</span>\n                {% endif %}\n            </div>\n            <div class=\"col-xs-6\">\n                <div style=\"margin-bottom: 4px;\">\n                    <span class=\"label-grey\">INCO:</span> {{ dn.incoterm or \"-\" }}\n                </div>\n                <div style=\"margin-bottom: 4px;\">\n                    <span class=\"label-grey\">PLACE:</span> {{ dn.named_place or \"-\" }}\n                </div>\n                <div style=\"margin-bottom: 4px;\">\n                    <span class=\"label-grey\">REF:</span> {{ dn.po_no or \"-\" }}\n                </div>\n                <div>\n                    <span class=\"label-grey\">CURRENCY:</span> {{ dn.currency }}\n                </div>\n            </div>\n        </div>\n        {% endif %}\n\n        <table class=\"table-custom\">\n            <thead>\n                <tr>\n                    <th style=\"width: 38%;\">Description of Goods</th>\n                    <th class=\"text-right\" style=\"width: 5%;\">Qty</th>\n                    <th style=\"width: 9%;\">UOM</th>\n                    <th style=\"width: 13%;\">Pallet Type</th>\n                    <th class=\"text-right\" style=\"width: 10%;\">No. of Pallets</th>\n                    <th style=\"width: 13%;\">Batch ID</th>\n                    <th style=\"width: 12%;\">Expiry</th>\n                </tr>\n            </thead>\n            <tbody>\n                {% for row in doc.items %}\n                    {% set expiry = frappe.db.get_value(\"Batch\", row.batch_no, \"expiry_date\") if row.batch_no else None %}\n                    <tr>\n                        <td>\n                            <div class=\"item-name-cell\">{{ row.item_code }}</div>\n                            {% if row.description %}\n                                <div class=\"item-description-text\">{{ row.description | striptags }}</div>\n                            {% endif %}\n                        </td>\n                        <td class=\"text-right\">{{ frappe.format_value(row.qty, {\"fieldtype\": \"Float\"}) }}</td>\n                        <td>{{ row.stock_uom or \"\" }}</td>\n                        <td>{{ row.custom_pallet_type or \"-\" }}</td>\n                        <td class=\"text-right\">\n                            {% if row.custom_pallet_qty %}\n                                {{ frappe.format_value(row.custom_pallet_qty, {\"fieldtype\": \"Float\"}) }}\n                            {% else %}\n                                -\n                            {% endif %}\n                        </td>\n                        <td>{{ row.batch_no or \"-\" }}</td>\n                        <td>{{ frappe.utils.formatdate(expiry) if expiry else \"-\" }}</td>\n                    </tr>\n                {% endfor %}\n            </tbody>\n        </table>\n\n        {% set uom_totals = {} %}\n        {% set pallet_totals = {} %}\n        {% for row in doc.items %}\n            {% if row.stock_uom %}\n                {% set _ = uom_totals.update({row.stock_uom: (uom_totals.get(row.stock_uom, 0) + (row.qty or 0))}) %}\n            {% endif %}\n            {% if row.custom_pallet_type and row.custom_pallet_qty %}\n                {% set _ = pallet_totals.update({row.custom_pallet_type: (pallet_totals.get(row.custom_pallet_type, 0) + (row.custom_pallet_qty or 0))}) %}\n            {% endif %}\n        {% endfor %}\n\n        {% if uom_totals or pallet_totals %}\n        <div class=\"package-stats\">\n            <div class=\"package-stats-heading\">Package Statistics</div>\n            <div class=\"row\">\n                {% if uom_totals %}\n                <div class=\"col-xs-6\">\n                    <table class=\"package-stats-table\">\n                        <thead><tr><th>UOM</th><th class=\"text-right\">Total Units</th></tr></thead>\n                        <tbody>\n                        {% for uom, qty in uom_totals.items()|sort %}\n                            <tr><td>{{ uom }}</td><td class=\"text-right\">{{ frappe.format_value(qty, {\"fieldtype\": \"Float\"}) }}</td></tr>\n                        {% endfor %}\n                        </tbody>\n                    </table>\n                </div>\n                {% endif %}\n                {% if pallet_totals %}\n                <div class=\"col-xs-6\">\n                    <table class=\"package-stats-table\">\n                        <thead><tr><th>Pallet Type</th><th class=\"text-right\">No. of Pallets</th></tr></thead>\n                        <tbody>\n                        {% for pt, qty in pallet_totals.items()|sort %}\n                            <tr><td>{{ pt }}</td><td class=\"text-right\">{{ frappe.format_value(qty, {\"fieldtype\": \"Float\"}) }}</td></tr>\n                        {% endfor %}\n                        </tbody>\n                    </table>\n                </div>\n                {% endif %}\n            </div>\n        </div>\n        {% endif %}\n\n        {% if doc.net_weight_pkg or doc.gross_weight_pkg %}\n        <div class=\"weights-footer text-right\">\n            {% if doc.net_weight_pkg %}\n                <strong>Net Weight:</strong> {{ frappe.format_value(doc.net_weight_pkg, {\"fieldtype\": \"Float\"}) }} {{ doc.net_weight_uom or \"\" }}\n            {% endif %}\n            {% if doc.gross_weight_pkg %}\n                &nbsp;&nbsp;<strong>Gross Weight:</strong> {{ frappe.format_value(doc.gross_weight_pkg, {\"fieldtype\": \"Float\"}) }} {{ doc.gross_weight_uom or \"\" }}\n            {% endif %}\n        </div>\n        {% endif %}\n\n    </div>\n</div>\n",
